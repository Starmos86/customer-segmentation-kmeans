    "    ('Recency', 'Frequency', 'orangered', 'Recency (days)', 'Frequency'),\n",
    "    ('Recency', 'Monetary', 'steelblue', 'Recency (days)', 'Monetary Value'),\n",
    "    ('Frequency', 'Monetary', 'darkorange', 'Frequency', 'Monetary Value')\n",
    "]\n",
    "\n",
    "# -----------------------------\n",
    "# Regression plots\n",
    "# -----------------------------\n",
    "for i, (x, y, color, xlabel, ylabel) in enumerate(regplot_settings):\n",
    "    sns.regplot(data=rfm, x=x,y=y,color=color, ax=axes[i],scatter_kws={'alpha': 0.7},line_kws={'linewidth': 2},robust=True)\n",
    "    axes[i].set(title=f'{x} vs {y}',xlabel=xlabel,ylabel=ylabel)\n",
    "    axes[i].grid(True, linestyle='--', alpha=0.5)\n",
    "\n",
    "# -----------------------------\n",
    "# d) Correlation heatmap\n",
    "# -----------------------------\n",
    "corr_matrix = rfm[['Recency', 'Frequency', 'Monetary']].corr(method='kendall')\n",
    "sns.heatmap(corr_matrix,annot=True,fmt='.2f',cmap='coolwarm',linewidths=0.5,linecolor='white',annot_kws={'fontsize': 10, 'weight': 'bold'},ax=axes[3])\n",
    "axes[3].set_title('Correlation Analysis (Kendall)')\n",
