    "# a) Import transformer\n",
    "from sklearn.preprocessing import PowerTransformer\n",
    "\n",
    "# b) Select RFM features\n",
    "X = rfm[['Recency', 'Frequency', 'Monetary']].copy()\n",
    "\n",
    "# c) Apply Yeo-Johnson transformation\n",
    "pt = PowerTransformer(method='yeo-johnson',standardize=False) \n",
    "X_transformed = pt.fit_transform(X)\n",
    "\n",
    "# d) Insert X_transformed data into rfm dataframe as new columns\n",
    "rfm[['Recency_t', 'Frequency_t', 'Monetary_t']] = X_transformed\n",
    "# Keep transformed columns alongside raw RFM values (rather than replacing them)\n",
    "# so we can compare pre/post-transformation distributions in the diagnostic plots below\n",
    "\n",
    "# e) Preview\n",
    "rfm.head()\n"
