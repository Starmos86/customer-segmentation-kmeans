    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "# Feature standardization\n",
    "scaler =StandardScaler()\n",
    "\n",
    "# Since the RFM variables were already transformed to reduce skewness and the influence of extreme values,\n",
    "# StandardScaler is  applied to standardize each feature by centering the data around a mean of 0 and scaling it to a standard deviation of 1.\n",
    "# This ensures that each RFM dimension contributes equally to the clustering process, allowing K-Means to identify customer groups based on overall purchasing behavior rather than differences in feature magnitude.\n",
    "\n",
    "# Alternative scalers:\n",
    "# - RobustScaler: Better when extreme outliers remain after transformation. It uses the median and interquartile range (IQR) instead of mean and standard deviation.\n",
    "# - MinMaxScaler: Useful when preservinga  a fixed range (typically [0, 1]) is important,especially for algorithms sensitive to feature magnitude.\n",
    "\n",
    "X_scaled = scaler.fit_transform(rfm[['Recency_t', 'Frequency_t', 'Monetary_t']])\n",
    "\n",
    "# Insert X_scaled data into rfm dataframe as new columns\n",
    "rfm[['Recency_s', 'Frequency_s', 'Monetary_s']] = X_scaled\n",
    "rfm.head()"
   ]
