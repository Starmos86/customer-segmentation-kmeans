   "source": [
    "# Based on the cluster profiles above:\n",
    "# - Lower Recency + highest Frequency + highest Monetary -> High Value / Loyal Customers\n",
    "# - Lowest Recency + moderate Frequency + moderate Monetary -> Potential Loyal Customers\" Active / Growth Customers\n",
    "# - Higher Recency + relatively high Frequency + high Monetary -> At-Risk High-Value Customers\n",
    "# - Highest Recency + lowest Frequency + lowest Monetary -> Low Value / At-Risk Customers\n",
    "\n",
    "# -------------------------------------------------\n",
    "# Define mapping\n",
    "\n",
    "cluster_relabeled = {\n",
    "    0: \"At-Risk High-Value Customers\",\n",
    "    1: \"Low Value / At-Risk Customers\",\n",
    "    2: \"High Value / Loyal Customers\",\n",
    "    3: \"Potential Loyal Customers\"\n",
    "}\n",
    "\n",
    "\n",
    "# Map cluster labels to descriptive segment names\n",
    "rfm_clustered[\"Segment\"] = rfm_clustered['K4_Cluster'].map(cluster_relabeled)\n",
    "\n",
    "rfm_clustered[[\"Customer ID\", \"K4_Cluster\", \"Segment\"]].head()"
   ]
