   "source": [
    "# ============================================================\n",
    "# Generate Cluster Profiles for K = 2\n",
    "# ============================================================\n",
    "\n",
    "# Calculate average RFM characteristics and customer counts for each cluster identified by the K = 2 model\n",
    "summary_k2 = ( rfm_clustered.groupby('K2_Cluster').agg(\n",
    "        Avg_Recency=('Recency', 'mean'),\n",
    "        Avg_Frequency=('Frequency', 'mean'),\n",
    "        Avg_Monetary=('Monetary', 'mean'),\n",
    "        Customers=('K2_Cluster', 'size')).round(2))\n",
    "\n",
    "# Calculate the percentage of customers belonging to each cluster\n",
    "summary_k2['Percentage (%)'] = (summary_k2['Customers'] / len(rfm_clustered) * 100).round(1)\n",
    "\n",
    "# Rename index for readability\n",
    "summary_k2.index.name = 'Cluster ID'\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# Generate Cluster Profiles for K = 4\n",
    "# ============================================================\n",
    "\n",
    "# Calculate average RFM characteristics and customer counts for each cluster identified by the K = 4 model\n",
    "summary_k4 = (rfm_clustered.groupby('K4_Cluster').agg(\n",
    "        Avg_Recency=('Recency', 'mean'),\n",
    "        Avg_Frequency=('Frequency', 'mean'),\n",
    "        Avg_Monetary=('Monetary', 'mean'),\n",
    "        Customers=('K4_Cluster', 'size')).round(2))\n",
    "\n",
    "# Calculate the percentage of customers belonging to each cluster\n",
    "summary_k4['Percentage (%)'] = (summary_k4['Customers'] / len(rfm_clustered) * 100).round(1)\n",
    "\n",
    "# Rename index for readability\n",
    "summary_k4.index.name = 'Cluster ID'\n",
    "\n",
    "# ============================================================\n",
    "# Display Cluster Profiles Separately\n",
    "# ============================================================\n",
    "\n",
    "from IPython.display import display, Markdown   # used only for better formatting instead of print()\n",
    "\n",
    "# Display K = 2 results\n",
    "display(Markdown(\"#### K = 2 Cluster Profiles\"))\n",
    "display(summary_k2)\n",
    "\n",
    "\n",
    "# Separator\n",
    "print(\"===\"*25)\n",
    "\n",
    "\n",
    "# Display K = 4 results\n",
    "display(Markdown(\"#### K = 4 Cluster Profiles\"))\n",
    "display(summary_k4)\n"
   ]
