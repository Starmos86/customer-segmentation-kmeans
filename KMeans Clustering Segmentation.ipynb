    "from sklearn.cluster import KMeans\n",
    "from sklearn.metrics import silhouette_score, calinski_harabasz_score\n",
    "\n",
    "# ----------------------------\n",
    "# Range of K\n",
    "# ----------------------------\n",
    "K = range(2,10)\n",
    "\n",
    "# ----------------------------\n",
    "# Metrics storage\n",
    "# ----------------------------\n",
    "inertia = []  \n",
    "silhouette = []\n",
    "calinski = []\n",
    "\n",
    "# ----------------------------\n",
    "# Model evaluation loop\n",
    "# ----------------------------\n",
    "for k in K:\n",
    "    km = KMeans(n_clusters=k, init='k-means++', n_init=1000, random_state=42)  # See note below about the choice of  n_init=1000 and random_state=42\n",
    "\n",
    "    labels = km.fit_predict(X_model)\n",
    "\n",
    "    # Elbow (WCSS)\n",
    "    inertia.append(km.inertia_)\n",
    "\n",
    "    # Silhouette Score\n",
    "    silhouette.append(silhouette_score(X_model, labels))\n",
    "\n",
    "    # Calinski-Harabasz Index\n",
    "    calinski.append(calinski_harabasz_score(X_model, labels))\n",
    "\n",
    "# ----------------------------\n",
    "# Print results\n",
    "# ----------------------------\n",
    "for k, i, s, c in zip(K, inertia, silhouette, calinski):\n",
    "    print(f\"K={k:<2} | WCSS={i:.2f} | Silhouette={s:.4f} | CH={c:.2f}\")\n",
    "\n",
    "# ----------------------------\n",
    "#  Auto elbow detection (to avoid bad interpretation)\n",
    "# ----------------------------\n",
    "from kneed import KneeLocator\n",
    "kneedle = KneeLocator(K, inertia, curve='convex', direction='decreasing')\n",
    "optimal_k = kneedle.elbow\n",
    "print(f\"Optimal K (Elbow): {optimal_k}\")\n",
    "\n",
    "# ----------------------------\n",
    "# Plot results\n",
    "# ----------------------------\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "\n",
    "# 1) Elbow (WCSS)\n",
    "axes[0].plot(K, inertia, marker=\"o\")\n",
    "axes[0].set_title(\"Elbow Method (WCSS)\")\n",
    "axes[0].set_xlabel(\"Number of Clusters (K)\")\n",
    "axes[0].set_ylabel(\"WCSS (Inertia)\")\n",
    "\n",
    "if optimal_k is not None:\n",
    "    axes[0].axvline(optimal_k, linestyle=\"--\", color=\"green\")\n",
    "#----------------------------------------\n",
    "\n",
    "# 2) Silhouette Score\n",
    "axes[1].plot(K, silhouette, marker=\"o\")\n",
    "axes[1].set_title(\"Silhouette Score\")\n",
    "axes[1].set_xlabel(\"Number of Clusters (K)\")\n",
    "axes[1].set_ylabel(\"Score\")\n",
    "\n",
    "#-------------------------------------\n",
    "# 3) Calinski-Harabasz\n",
    "axes[2].plot(K, calinski, marker=\"o\")\n",
    "axes[2].set_title(\"Calinski-Harabasz Score\")\n",
    "axes[2].set_xlabel(\"Number of Clusters (K)\")\n",
    "axes[2].set_ylabel(\"Score\")\n",
    "\n",
    "# ----------------------------\n",
    "# Layout adjustment\n",
    "# ----------------------------\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "#-----------------------------------------\n",
    "# Note: \n",
    "# n_init=1000 is used to improve confidence in clustering stability by evaluating a large number of centroid initializations.\n",
    "# Comparison with n_init=50 produced nearly identical results (similar WCSS, Silhouette Score, and Calinski-Harabasz Index values, with minimal\n",
    "# changes in cluster composition), indicating that k-means++ initialization already provides a stable solution for this dataset.\n",
