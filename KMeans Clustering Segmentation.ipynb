   "source": [
    "# a) Key variables for the RFM model\n",
    "df = DF[['Customer ID', 'Order ID', 'Order Date', 'Sales']]\n",
    "\n",
    "\n",
    "# b) Compute RFM variables\n",
    "\n",
    "# Define reference date (end of observation period + 1 day) to ensure all recency values are positive and comparable\n",
    "reference_date= df['Order Date'].max() + pd.Timedelta(days=1)\n",
    "\n",
    "# An aggregate method is used  here (using a single groupby aggregation)\n",
    "rfm = df.groupby('Customer ID').agg(\n",
    "    Recency=('Order Date', lambda x: (reference_date - x.max()).days), # difference between reference date and the last purchase date per customer.\n",
    "    Frequency=('Order ID', 'nunique'),                                 # number of unique purchases per customer\n",
    "    Monetary=('Sales', 'sum')).reset_index()                           # total revenue generated by a customer.\n",
    "\n",
    "\n",
    "# Preview final RFM table\n",
    "rfm.head()\n",
    "#----------------------------------------------------------------------------------------------------------------\n"
   ]
